# KTrade PRO v9 — Environment Variables
# Copy to .env, fill in values. NEVER commit to GitHub.

# ── Alpaca Paper Trading ──────────────────────────────────────────
ALPACA_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Polygon.io (NEW in v9 — replaces yfinance) ───────────────────
# Free key at https://polygon.io
POLYGON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POLYGON_SCAN_DELAY_SECONDS=1.0

# Finnhub optional market data/news fallback
# Free key at https://finnhub.io
FINNHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KTRADE_SCAN_UNIVERSE=core
# Optional custom list, comma-separated. If set, this overrides KTRADE_SCAN_UNIVERSE.
# KTRADE_SCAN_SYMBOLS=SPY,QQQ,NVDA,AAPL

# ── Agent Settings ────────────────────────────────────────────────
ACCOUNT_VALUE=100000
RISK_PER_TRADE=0.005
LIVE_TRADING=false
# ── Autonomous PAPER trading ──────────────────────────────────────
# Set true to let the agent place PAPER bracket orders autonomously.
# No real money — this targets the Alpaca PAPER endpoint only.
KTRADE_PAPER_ORDER_SUBMISSION=true
# IMPORTANT interaction (v12.8 regime guard): the autonomous loop refuses new
# entries when there is no FRESH VIX feed. With no market_fn wired you MUST set
# the next line false to actually place paper trades — you are then trading BLIND
# to regime (acceptable for paper data-collection, NOT for live). Wire a real VIX
# feed and set this back to true before any live capital.
KTRADE_REQUIRE_FRESH_VIX=false
# Whipsaw gate (v12.9): skip BUYs whose latest-session high-low range exceeds %.
KTRADE_MAX_INTRADAY_RANGE_PCT=40
# Desync guard (v12.8): halt new entries on broker-truth desync; auto-flatten off.
KTRADE_MAX_BROKER_FAILS=3
KTRADE_DESYNC_AUTO_FLATTEN=false
MIN_CONVICTION_SCORE=60
MAX_POSITIONS_PER_HEARTBEAT=3
DAILY_LOSS_LIMIT_PCT=0.02
MAX_DAILY_API_CALLS=500
COST_BUDGET_USD=5.0
MAX_SIGNAL_AGE_DAYS=2
COMMISSION_PER_TRADE=0
MAX_COST_FRAC=0.005
USE_CRASH_GUARD=true
SECTOR_ROTATION=true

# ── Optional: Alerts ─────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+1xxxxxxxxxx
# ALERT_TO=+1xxxxxxxxxx

# ── Optional: Robinhood fallback ─────────────────────────────────
# RH_USERNAME=your@email.com
# RH_PASSWORD=yourpassword

# Data provider: auto, polygon, alpaca, finnhub, or yfinance
KTRADE_DATA_PROVIDER=auto


# Optional OpenAI + FinBERT sentiment explanation
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_SENTIMENT_MODEL=gpt-4o-mini
KTRADE_ENABLE_OPENAI_SENTIMENT=true
KTRADE_ENABLE_FINBERT=true
KTRADE_SENTIMENT_TTL_SECONDS=1800
KTRADE_FINBERT_LOCAL_ONLY=true

# Safety checks
# BUY is downgraded to WATCH if scanner price differs from Alpaca reference by more than this percent.
KTRADE_MAX_PRICE_DIFF_PCT=5
# Keep 1 for free/low-rate plans. Increase carefully only on paid data plans.
KTRADE_SCAN_WORKERS=1

# Optional backend-only AI Advisor. Never put this key in the browser/frontend.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Copilot advisory layer (v13.0, Milestone 2) ───────────────────
# An LLM second-opinion over the deterministic rule decisions. Modes:
#   off    = never called (zero cost / zero behavior change).
#   shadow = logs a SKIP/BUY opinion + reasoning to the audit ledger, but NEVER
#            changes what trades. START HERE to collect data.
#   active = a SKIP/HOLD opinion can VETO a rule-approved BUY (it can never
#            CREATE a buy). Promote to this ONLY after the ledger shows it helps.
# Any LLM error / missing key -> ABSTAIN -> fail-open (defers to the rules; LLM
# downtime can never block trading). Note: there is NO live news feed, so the
# copilot reasons from technicals + held positions + regime + its own knowledge.
KTRADE_COPILOT_MODE=shadow
KTRADE_COPILOT_MODEL=claude-sonnet-4-6
KTRADE_COPILOT_TIMEOUT_S=20
# Audit ledger (append-only JSONL): logs/ktrade_copilot_ledger.jsonl by default.

# ── Volatility-regime estimator (v13.3, SHADOW) ───────────────────
# Logs the current vol regime + transition probabilities to a ledger each cycle.
#   off    = not computed.
#   shadow = logged for later analysis; changes NOTHING about trading.
# Evaluate it OFFLINE first before considering it for sizing:
#   python agent/regime_estimator.py --prices spy.csv
# (needs the benchmark below present in the scan/data set to log live).
KTRADE_REGIME_MODE=off
KTRADE_REGIME_BENCHMARK=SPY

# ── Dashboard Auto Trading (PAPER ONLY) ─────────────────────────
# Required for manual and automatic dashboard order endpoints.
# Keep false until you are ready to test with Alpaca paper trading.
KTRADE_ADMIN_TOKEN=change-this-long-random-token
KTRADE_ENABLE_AUTO_TRADING=false
KTRADE_AUTO_TRADE_INTERVAL_SECONDS=300
KTRADE_AUTO_TRADE_MIN_CONVICTION=80
KTRADE_AUTO_TRADE_QTY=1
KTRADE_AUTO_TRADE_MAX_ORDERS_PER_CYCLE=2
KTRADE_AUTO_TRADE_STOP_LOSS_PCT=3.0
KTRADE_AUTO_TRADE_TAKE_PROFIT_PCT=6.0
KTRADE_AUTO_TRADE_REQUIRE_SENTIMENT=false
KTRADE_AUTO_TRADE_ALLOW_DEMO=false

# ── v11.1: Paper→Live promotion gate ─────────────────────────────────────────
# A symbol must prove itself on paper before the agent may send it a LIVE order.
# DISABLED by default — turning it on only starts building the ledger; it does
# NOT change paper behaviour and can only ever block LIVE buys for unproven names.
KTRADE_PROMOTION_ENABLED=false
KTRADE_PROMOTION_MIN_TRADES=5            # min closed paper round-trips
KTRADE_PROMOTION_MIN_WIN_RATE=0.55      # 0.55 = 55%
KTRADE_PROMOTION_MIN_AVG_PNL=0.0        # min average $ P&L per trade
KTRADE_PROMOTION_TRIAL_DAYS=5           # min days observed before graduating
KTRADE_PROMOTION_REQUIRE_NET_POSITIVE=true
# Live mode is detected from LIVE_TRADING or KTRADE_LIVE_TRADING (either true).

# ── v11.2: Regime strategy-switch ────────────────────────────────────────────
# Switches the active entry posture by market regime + VIX. DISABLED by default
# (baseline = no behaviour change). When on, it can only make entries STRICTER /
# SMALLER or block new longs in weaker regimes — it never loosens the RiskEngine.
#   BULL      -> "momentum"             base-5 conviction, full size
#   NEUTRAL   -> "balanced"             baseline
#   RISK_OFF  -> "mean-reversion"       base+8 conviction, half size
#   CRASH     -> "capital-preservation" no new longs
# VIX overlay escalates a stale-calm regime: >=25 NEUTRAL, >=30 RISK_OFF, >=40 CRASH.
KTRADE_STRATEGY_SWITCH_ENABLED=false
# KTRADE_VIX=18        # optional manual VIX if the scan snapshot lacks one

# ── v11.3 (Milestone 1): Portfolio source-of-truth + audit + kill-switch matrix ──
# Optional KTrade portfolio-level risk gate. Disabled by default.
# DISABLED by default -> all portfolio gates allow (behaviour unchanged).
KTRADE_PORTFOLIO_GATE_ENABLED=false
KTRADE_PORTFOLIO_SNAPSHOT=data/portfolio_snapshot.json
KTRADE_PORTFOLIO_HMAC_SECRET=change-this-shared-secret
KTRADE_PORTFOLIO_MAX_STALE_MIN=60        # feed older than this fails SAFE
KTRADE_PORTFOLIO_MAX_POSITION_PCT=5      # single position <= % of TOTAL net worth
KTRADE_PORTFOLIO_MAX_DEPLOYED_PCT=30     # total deployed <= % of TOTAL net worth
KTRADE_NETWORTH_DD_HALT_PCT=15           # halt new longs if net worth -% from peak
KTRADE_PORTFOLIO_MAX_JUMP_PCT=35         # reject snapshot if net worth jumps >% (bad data)
KTRADE_PORTFOLIO_FAIL_MODE=block         # stale/missing feed -> "block" (risk-first) | "allow"


# Example External Portfolio app support folder on macOS; set only if using SQLite mode.

# Immutable, hash-chained decision audit trail (pure logging; on by default).
KTRADE_AUDIT_ENABLED=true
KTRADE_AUDIT_PATH=logs/ktrade_audit.jsonl

# Manual dashboard execution safety
KTRADE_MANUAL_ALLOW_DEMO=false
# Manual BUYs now use bracket orders and require trusted scan price references.

# --- KTrade V12.2 local runtime paths (optional) ---
# Keep secrets/logs/DB outside the source folder for local desktop-style use.
# Leave blank to use OS defaults:
#   macOS: ~/Library/Application Support/KTrade
#   Windows: %LOCALAPPDATA%\KTrade
#   Linux: ~/.local/share/ktrade
KTRADE_APP_DATA_DIR=
KTRADE_ENV_FILE=
KTRADE_LOG_DIR=
KTRADE_DB_PATH=
KTRADE_AGENT_LOG=
KTRADE_BIND_HOST=127.0.0.1
KTRADE_PORT=5001
KTRADE_PREVENT_SLEEP=true
